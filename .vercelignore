# Vercel 部署排除清單 — 不會被打包進 production
# 參考: https://vercel.com/docs/concepts/projects/vercelignore

# 大型污染目錄
v2/
v2/**
v2/node_modules/

# 開發工具狀態 (已在 .gitignore,但保險再寫一次)
.opencode/
.swarm/
.omo/
.vercel/

# GitHub / VCS
.github/
.git/
.gitignore
.gitattributes

# 文件 / 計畫 (不部署)
docs/
AGENTS.md
CHANGELOG.md
README.md

# data/ 整體不部署 (dev 用)
// runtime 需要的 reviews.json 已搬到 assets/data/reviews.json (v10.4)
data/
data/**

# 隱藏檔
.*
*.bak
*.bak.*
index.html.bak
original_full.html
Thumbs.db
.DS_Store

# 測試 / 備份
test-output/
coverage/
.tmp_*.js
.tmp_*.py
*.log
npm-debug.log*

# 編輯器
.vscode/
.idea/
*.swp
