# 美食遊覽 環境變數範例
# 部署到 Vercel 時, 設到 Project Settings > Environment Variables
# 本地開發可複製為 .env.local (會被 .gitignore 排除)

# Supabase 連線設定
SUPABASE_URL=https://你的專案.supabase.co
SUPABASE_ANON_KEY=你的_anon_public_key

# 取得方式:
# 1. 註冊 https://supabase.com (免費)
# 2. Create new project → 選 region (Singapore 或 Tokyo)
# 3. Settings > API > Project URL + anon public key
# 4. SQL Editor 執行 supabase/migrations/001_initial_schema.sql
